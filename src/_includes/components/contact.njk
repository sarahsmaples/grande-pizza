<div class="relative bg-white dark:bg-gray-900">
  <div class="lg:absolute lg:inset-0 lg:left-1/2">
    <img src="/assets/images/contact-bg.jpg" alt="Restaurant dining area" class="h-64 w-full bg-gray-50 object-cover sm:h-80 lg:absolute lg:h-full dark:bg-gray-800" />
  </div>
  <div class="pb-24 pt-16 sm:pb-32 sm:pt-24 lg:mx-auto lg:grid lg:grid-cols-2 lg:pt-32">
    <div class="px-6 lg:px-24">
      <div class="lg:mx-0">
        <h2 class="text-pretty text-4xl font-semibold tracking-tight text-gray-900 sm:text-5xl dark:text-white">Contact Us</h2>
        <p class="text-2xl font-medium text-gray-900 dark:text-white">{{ client.restaurantName }}</p>
        
        <div class="mt-8 grid grid-cols-1 gap-8 sm:grid-cols-2">
          <div>
            <h3 class="flex items-center text-lg font-medium text-gray-900 dark:text-white">
              <svg class="mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              Address
            </h3>
            <address class="mt-2 not-italic text-gray-600 dark:text-gray-400">
              {{ client.address.street }}<br>
              {{ client.address.city }}, {{ client.address.state }} {{ client.address.zip }}
            </address>
            <a href="{{ client.googleMapsUrl }}" class="mt-2 inline-block text-indigo-600 hover:text-indigo-500 dark:text-indigo-400" target="_blank">Open in Google Maps</a>
          </div>
          
          <div>
            <h3 class="flex items-center text-lg font-medium text-gray-900 dark:text-white">
              <svg class="mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              Hours
            </h3>
            <div class="mt-2">
              <table class="w-full text-sm text-gray-600 dark:text-gray-400">
                <thead>
                  <tr class="border-b border-gray-200 dark:border-gray-600">
                    <th class="text-left py-1 font-medium text-gray-900 dark:text-white text-xs">Day</th>
                    <th class="text-left py-1 font-medium text-gray-900 dark:text-white text-xs">Lunch</th>
                    <th class="text-left py-1 font-medium text-gray-900 dark:text-white text-xs">Dinner</th>
                  </tr>
                </thead>
                <tbody>
                  {% for schedule in client.hours.schedule %}
                  <tr>
                    <td class="py-0.5 text-xs">{{ schedule.day }}</td>
                    <td class="py-0.5 text-xs">{{ schedule.lunch }}</td>
                    <td class="py-0.5 text-xs">{{ schedule.dinner }}</td>
                  </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>
          </div>
        </div>
        
        <h3 class="mt-8 text-lg font-medium text-gray-900 dark:text-white">Send us a message</h3>
        <iframe src="{{ client.contactFormUrl }}" frameborder="0" width="100%" height="545" scrolling="no" class="mt-4"></iframe>
      </div>
    </div>
  </div>
</div>


