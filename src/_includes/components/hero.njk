<div class="bg-white">
  <div class="relative isolate overflow-hidden flex items-center hero-with-header">
    <video
      autoplay
      loop
      muted
      playsinline
      preload="metadata"
      poster="/assets/images/thumbnail.jpg"
      aria-hidden="true"
      class="absolute inset-0 -z-10 size-full object-cover"
    >
      <source src="/assets/videos/hero.webm" type="video/webm">
      <source src="/assets/videos/hero.mp4" type="video/mp4">
    </video>
    <div class="absolute inset-0 -z-10 bg-black opacity-60"></div>

    <div class="mx-auto w-full max-w-7xl px-6 lg:px-16">
      <div class="flex flex-col items-center lg:flex-row lg:items-center lg:gap-16">

        <!-- Logo: entrance scale + continuous float -->
        <div class="flex-shrink-0 hero-logo-float">
          {% image "/assets/images/logo.png", client.restaurantName, "(max-width: 1024px) min(90vw, 400px), 500px", [300, 500, 800, 1000], "", "hero-logo w-[90%] max-w-[400px] mx-auto lg:mx-0 lg:w-[500px] lg:max-w-none", "eager" %}
        </div>

        <!-- Text + CTAs: slide in from right on load -->
        <div class="mt-6 lg:mt-0 text-center lg:text-left" data-reveal="right" data-delay="400">
          <h1 class="hidden lg:block font-heading text-5xl xl:text-6xl text-white uppercase leading-tight">{{ client.hero_title }}</h1>
          <p class="hidden lg:block mt-4 text-lg text-gray-200/90">{{ client.hero_subtitle }}</p>
          <div class="mt-2 lg:mt-8 flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
            <a href="/menus/" class="inline-block text-center border-2 border-white text-white font-heading text-xl uppercase px-10 py-4 rounded-full hover:bg-white hover:text-secondary-700 transition-colors">View Menu</a>
            <a href="{{ client.orderUrl }}" class="inline-block text-center bg-primary-500 hover:bg-primary-400 text-white font-heading text-xl uppercase px-10 py-4 rounded-full transition-colors">Order Now</a>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>
