<header class="fixed lg:top-16 left-0 right-0 z-50">
  <!-- Logo Container - Overlays the header -->
  <div class="hidden lg:block absolute left-1/2 top-1/2 transform -translate-x-1/2 -translate-y-1/2 z-20">
    <div class="bg-secondary-700 rounded-lg px-6 py-6 border border-white/30 shadow-lg">
      <a href="/" class="block">
        <span class="sr-only">{{ client.restaurantName }}</span>
        <img src="/assets/images/logo.png" alt="{{ client.restaurantName }} Logo" class="w-64 h-[71px]" />
      </a>
    </div>
  </div>

    <!-- Inner container with borders and background -->
    <div class="bg-secondary-700 py-[5px]">
      <div class="border-t border-b border-white">
        <nav aria-label="Global" class="px-4 sm:px-6 lg:px-8 flex items-center justify-between lg:justify-normal py-4">

          <!-- Left Navigation -->
          <div class="hidden lg:flex lg:flex-1 lg:items-center lg:justify-between lg:gap-x-8 lg:pr-8">
            <a href="#about" class="text-lg font-normal text-white hover:text-gray-300 transition-colors uppercase">About</a>
            <a href="/menus/" class="text-lg font-normal text-white hover:text-gray-300 transition-colors uppercase">Menu</a>
            <a href="#gallery" class="text-lg font-normal text-white hover:text-gray-300 transition-colors uppercase">Gallery</a>
          </div>

          <!-- Mobile Logo -->
          <div class="flex lg:hidden">
            <a href="/" class="block">
              <span class="sr-only">{{ client.restaurantName }}</span>
              <img src="/assets/images/logo.png" alt="{{ client.restaurantName }} Logo" class="h-12 w-auto" />
            </a>
          </div>

          <!-- Mobile menu button -->
          <div class="flex lg:hidden">
            <button type="button" command="show-modal" commandfor="mobile-menu-center" class="-m-2.5 inline-flex items-center justify-center rounded-md p-2.5 text-white">
              <span class="sr-only">Open main menu</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" data-slot="icon" aria-hidden="true" class="size-6">
                <path d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </button>
          </div>

          <!-- Center Space for Logo -->
          <div class="hidden lg:block flex-shrink-0 w-80">
            <!-- Empty space where logo overlays -->
          </div>

          <!-- Right Navigation -->
          <div class="hidden lg:flex lg:flex-1 lg:items-center lg:justify-between lg:gap-x-8 lg:pl-8">
            <a href="#contact" class="text-lg font-normal text-white hover:text-gray-300 transition-colors uppercase">Contact</a>
            <a href="http://88restaurants.com/{{ client.id }}/online_orders/new" class="text-lg font-normal text-white hover:text-gray-300 transition-colors uppercase">Order</a>
            <a href="https://88restaurants.com/{{ client.id }}/reservations/restaurants/booking_details" class="text-lg font-normal text-white hover:text-gray-300 transition-colors uppercase">Reserve</a>
          </div>
        </nav>
      </div>
    </div>

  <!-- Mobile Menu Dialog -->
  <el-dialog>
    <dialog id="mobile-menu-center" class="m-0 p-0 backdrop:bg-transparent lg:hidden">
      <div tabindex="0" class="fixed inset-0 focus:outline focus:outline-0">
        <el-dialog-panel class="fixed inset-y-0 right-0 z-50 w-full overflow-y-auto bg-white p-6 sm:max-w-sm sm:ring-1 sm:ring-gray-900/10">
          <div class="flex items-center justify-between">
            <a href="/" class="-m-1.5 p-1.5">
              <span class="sr-only">{{ client.restaurantName }}</span>
              <img src="/assets/images/logo.png" alt="{{ client.restaurantName }} Logo" class="h-16 w-auto" />
            </a>
            <button type="button" command="close" commandfor="mobile-menu-center" class="-m-2.5 rounded-md p-2.5 text-gray-700">
              <span class="sr-only">Close menu</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" data-slot="icon" aria-hidden="true" class="size-6">
                <path d="M6 18 18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </button>
          </div>
          <div class="mt-6 flow-root">
            <div class="-my-6 divide-y divide-gray-500/10">
              <div class="space-y-2 py-6">
                <a href="#about" class="-mx-3 block rounded-lg px-3 py-2 text-base/7 font-normal text-gray-900 hover:bg-gray-50 uppercase">About</a>
                <a href="/menus/" class="-mx-3 block rounded-lg px-3 py-2 text-base/7 font-normal text-gray-900 hover:bg-gray-50 uppercase">Menu</a>
                <a href="#gallery" class="-mx-3 block rounded-lg px-3 py-2 text-base/7 font-normal text-gray-900 hover:bg-gray-50 uppercase">Gallery</a>
                <a href="#contact" class="-mx-3 block rounded-lg px-3 py-2 text-base/7 font-normal text-gray-900 hover:bg-gray-50 uppercase">Contact</a>
                <a href="http://88restaurants.com/{{ client.id }}/online_orders/new" class="-mx-3 block rounded-lg px-3 py-2 text-base/7 font-normal text-gray-900 hover:bg-gray-50 uppercase">Order</a>
                <a href="https://88restaurants.com/{{ client.id }}/reservations/restaurants/booking_details" class="-mx-3 block rounded-lg px-3 py-2 text-base/7 font-normal text-gray-900 hover:bg-gray-50 uppercase">Reserve</a>
              </div>
            </div>
          </div>
        </el-dialog-panel>
      </div>
    </dialog>
  </el-dialog>
</header>
