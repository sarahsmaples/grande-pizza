<!--
  PARALLAX SECTION BREAK
  ======================
  
  A visual break section between major content areas using parallax scrolling effect.
  
  CLIENT CUSTOMIZATION:
  - Replace placeholder-parallax.jpg with client's image
  - Recommended image size: 1920x1080px or larger
  - Format: JPEG or WebP for best performance
  - Ensure good contrast if adding text overlay later
  
  RESPONSIVE HEIGHTS:
  - Mobile: 40vh (manageable on small screens)
  - Tablet: 50vh 
  - Desktop: 60vh (impactful visual break)
-->

<section class="relative h-[40vh] md:h-[50vh] lg:h-[60vh] overflow-hidden">
  <div 
    class="absolute inset-0 bg-cover bg-center bg-fixed"
    style="background-image: url('assets/images/parallax-bg-1.jpg')"
    aria-hidden="true"
  >
    <!-- Optional overlay for future text content -->
    <div class="absolute inset-0 bg-black bg-opacity-20"></div>
  </div>
</section>