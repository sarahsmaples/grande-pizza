<div class="relative bg-white">
  <div class="lg:absolute lg:inset-0 lg:left-1/2">
    <img src="assets/images/contact-bg.jpg" alt="Restaurant dining area" class="h-64 w-full bg-gray-50 object-cover sm:h-80 lg:absolute lg:h-full" />
  </div>
  <div class="pb-24 pt-16 sm:pb-32 sm:pt-24 lg:mx-auto lg:grid lg:grid-cols-2 lg:pt-32">
    <div class="px-6 lg:px-24">
      <div class="lg:mx-0">
        <h2 class="text-pretty text-3xl font-semibold tracking-tight text-gray-900 sm:text-5xl">Contact Us</h2>
        
        <!-- Mobile/Tablet: Stack all sections, Large screens: Address and Contact in first row -->
        <div class="mt-8 grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-2">
          <div>
            <h3 class="flex items-center text-lg font-medium text-gray-900">
              <svg class="mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              Address
            </h3>
            <address class="mt-2 not-italic text-gray-600">
              {{ client.address.street }}<br>
              {{ client.address.city }}, {{ client.address.state }} {{ client.address.zip }}
            </address>
            <a href="{{ client.googleMapsUrl }}" class="mt-2 inline-block text-primary-500 hover:text-primary-500" target="_blank">Open in Google Maps</a>
          </div>
          
          <div>
            <h3 class="flex items-center text-lg font-medium text-gray-900">
              <svg class="mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
              </svg>
              Contact
            </h3>
            <div class="mt-2 space-y-3">
              <div class="flex items-center">
                <svg class="mr-3 h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                </svg>
                <a href="tel:{{ client.phone }}" class="text-gray-600 hover:text-primary-500">{{ client.phone }}</a>
              </div>
              <div class="flex items-center">
                <svg class="mr-3 h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
                <a href="mailto:{{ client.email }}" class="text-gray-600 hover:text-primary-500">{{ client.email }}</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Hours section - mobile shows inline with above, desktop gets its own row -->
        <div class="lg:hidden mt-8">
          <h3 class="flex items-center text-lg font-medium text-gray-900">
            <svg class="mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            Hours
          </h3>
          <div class="mt-2 space-y-2">
            {% for schedule in client.hours.schedule %}
            <div>
              <div class="font-medium text-gray-900 text-sm mb-1">{{ schedule.day }}</div>
              <div class="text-sm text-gray-600">{{ schedule.lunch }}, {{ schedule.dinner }}</div>
            </div>
            {% endfor %}
          </div>
        </div>

        <!-- Hours section - desktop full width row -->
        <div class="hidden lg:block mt-8">
          <h3 class="flex items-center text-lg font-medium text-gray-900 mb-4">
            <svg class="mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            Hours
          </h3>
          <table class="w-full text-sm text-gray-600 max-w-lg">
            <thead>
              <tr class="border-b border-gray-200">
                <th class="text-left py-2 font-medium text-gray-900">Day</th>
                <th class="text-left py-2 font-medium text-gray-900">Lunch</th>
                <th class="text-left py-2 font-medium text-gray-900">Dinner</th>
              </tr>
            </thead>
            <tbody>
              {% for schedule in client.hours.schedule %}
              <tr>
                <td class="py-1">{{ schedule.day }}</td>
                <td class="py-1">{{ schedule.lunch }}</td>
                <td class="py-1">{{ schedule.dinner }}</td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
        
        <h3 class="mt-8 text-lg font-medium text-gray-900">Send us a message</h3>
        <iframe src="https://88restaurants.com/{{ client.id }}/contact_forms" frameborder="0" width="100%" height="545" scrolling="no" class="mt-4"></iframe>
      </div>
    </div>
  </div>
</div>


