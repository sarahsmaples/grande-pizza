<!--
  RESTAURANT GALLERY TEMPLATE
  ===========================
  
  IMAGE SIZING GUIDELINES FOR CLIENTS:
  
  THUMBNAIL IMAGES (for grid display):
  - Size: 400x400px (square format)
  - Format: JPEG or WebP
  - Quality: 75-85% compression
  - File size target: 15-40KB each
  - Naming: Use descriptive names (e.g., "beef-steak-thumb.jpg")
  
  FULL-SIZE IMAGES (for modal view):
  - Size: 1200x800px (3:2 aspect ratio recommended)
  - Format: JPEG or WebP  
  - Quality: 85-90% compression
  - File size target: 80-200KB each
  - Naming: Match thumbnail but with "-full" suffix (e.g., "beef-steak-full.jpg")
  
  HOW TO CUSTOMIZE:
  1. Replace placeholder images with client's food photos
  2. Update alt text and captions to describe actual dishes
  3. Ensure images follow the sizing guidelines above
  4. Test on mobile and desktop for optimal viewing
  
  CURRENT SETUP: Uses single placeholder image for all gallery items
-->

<section id="gallery" class="py-16 bg-secondary-700">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl px-4 lg:px-8 mb-10">
      <div class="mx-auto max-w-2xl sm:text-center">
        <h2 class="text-base/7 font-semibold text-primary-500">Gallery</h2>
        <p class="mt-2 text-pretty text-3xl font-semibold tracking-tight text-white sm:text-balance sm:text-5xl">Explore {{ client.name }}</p>
      </div>
    </div>
    
    <div itemtype="http://schema.org/ImageGallery" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 lg:gap-6 itemscope" id="gallery-grid">
      <!-- Gallery Item 1 -->
      <figure itemprop="associatedMedia" itemscope itemtype="http://schema.org/ImageObject" class="group cursor-pointer">
        <div class="aspect-square overflow-hidden bg-gray-200 shadow-md hover:shadow-lg transition-shadow duration-300">
          <img 
            src="assets/images/gallery/placeholder-thumb.jpg" 
            itemprop="thumbnail" 
            alt="Restaurant Gallery Image" 
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
            data-full-image="assets/images/gallery/placeholder-full.jpg"
          >
        </div>
      </figure>

      <!-- Gallery Item 2 -->
      <figure itemprop="associatedMedia" itemscope itemtype="http://schema.org/ImageObject" class="group cursor-pointer">
