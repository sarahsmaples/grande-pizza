<section id="contact" class="bg-cream-100 py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">

    <h2 class="font-heading text-4xl sm:text-6xl text-secondary-700 uppercase mb-16" data-reveal="up">Contact Us</h2>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">

      <!-- Left: Info -->
      <div class="space-y-10" data-reveal="left">

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        <div>
          <h3 class="font-heading text-xl text-primary-500 uppercase mb-3">Address</h3>
          <address class="not-italic text-secondary-700 leading-relaxed">
            {{ client.address.street }}<br>
            {{ client.address.city }}, {{ client.address.state }} {{ client.address.zip }}
          </address>
          <a href="{{ client.googleMapsUrl }}" target="_blank" rel="noopener noreferrer" class="mt-2 inline-block text-primary-500 hover:text-primary-600 text-sm">Open in Google Maps →</a>
        </div>

        <div>
          <h3 class="font-heading text-xl text-primary-500 uppercase mb-3">Contact</h3>
          <div class="space-y-2">
            <div><a href="tel:{{ client.phone }}" class="text-secondary-700 hover:text-primary-500 transition-colors">{{ client.phone }}</a></div>
            <div><a href="mailto:{{ client.email }}" class="text-secondary-700 hover:text-primary-500 transition-colors">{{ client.email }}</a></div>
          </div>
        </div>
        </div>

        <div>
          <h3 class="font-heading text-xl text-primary-500 uppercase mb-3">Hours</h3>
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-secondary-700/10">
                <th class="text-left py-2 font-medium text-secondary-700">Day</th>
                <th class="text-left py-2 font-medium text-secondary-700">Hours</th>
              </tr>
            </thead>
            <tbody>
              {% for schedule in client.hours.schedule %}
              <tr class="border-b border-secondary-700/5">
                <td class="py-2 text-secondary-700">{{ schedule.day }}</td>
                <td class="py-2 text-secondary-700">{{ schedule.hours }}</td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>

      </div>

      <!-- Right: Contact form -->
      <div data-reveal="right" data-delay="150">
        <h3 class="font-heading text-xl text-primary-500 uppercase mb-6">Send Us a Message</h3>
        <iframe src="{{ client.contactFormUrl }}" title="Contact Grande Pizza & Wings To Go" frameborder="0" width="100%" height="545" scrolling="no"></iframe>
      </div>

    </div>
  </div>
</section>
