                {% if client.socialMedia.googleBusiness %}
                <a href="{{ client.socialMedia.googleBusiness }}" target="_blank" rel="noopener noreferrer" class="text-primary-500 hover:text-primary-600">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 32 32">
                    <path d="M29.44,16.318c0-.993-.089-1.947-.255-2.864h-13.185v5.422h7.535c-.331,1.744-1.324,3.22-2.813,4.213v3.525h4.544c2.647-2.444,4.175-6.033,4.175-10.296Z" opacity=".4"/>
