                  </svg>
                </a>
                {% endif %}
              </div>
            </div>
            {% endif %}
          </div>
        </div>
      </div>
      {% for card in client.menuCards %}
      <div class="flex p-px col-span-1 lg:col-span-2">
        <a 
          href="#" 
          class="w-full overflow-hidden rounded-lg bg-white shadow outline outline-1 outline-black/5 relative group focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 hover:shadow-lg transition-shadow duration-300"
          aria-label="View {{ card.title }} menu - {{ card.pretitle }}"
        >
          <div class="h-64 sm:h-72 lg:h-80 w-full bg-cover bg-center relative group-hover:scale-105 transition-transform duration-300" style="background-image: url('{{ card.image }}');">
            <div class="absolute inset-0 bg-black/40"></div>
            <div class="absolute inset-0 flex flex-col items-center justify-center text-white text-center px-4">
              <h3 class="text-lg sm:text-xl lg:text-2xl font-bold tracking-tight uppercase">{{ card.name }}</h3>
            </div>
          </div>
        </a>
      </div>
      {% endfor %}
    </div>
  </div>
</div>
