
<div class="bg-gray-50 py-24 sm:py-32">
  <div class="mx-auto max-w-2xl px-6 lg:max-w-7xl lg:px-8">
    <h2 class="text-base/7 font-semibold text-primary-500">{{ client.cuisine }}</h2>
    <p class="mt-2 max-w-lg text-pretty text-3xl font-semibold tracking-tight text-gray-900 sm:text-5xl">{{ client.restaurantName }}</p>
    <div class="mt-10 grid grid-cols-1 gap-4 sm:mt-16 lg:grid-cols-6 lg:grid-rows-2">
      <div class="flex p-px lg:col-span-4">
        <div class="w-full overflow-hidden rounded-lg bg-white shadow outline outline-1 outline-black/5">
          <div class="p-5 lg:p-10">
            <h3 class="text-lg font-semibold text-primary-500">Hours</h3>
            <div class="mt-4">
              <!-- Desktop table view (lg and up) -->
              <table class="hidden lg:table w-full text-sm text-gray-600">
                <thead>
                  <tr class="border-b border-gray-200">
                    <th class="text-left py-2 font-medium text-gray-900">Day</th>
                    <th class="text-left py-2 font-medium text-gray-900">Hours</th>
                  </tr>
                </thead>
                <tbody>
                  {% for schedule in client.hours.schedule %}
                  <tr>
                    <td class="py-1">{{ schedule.day }}</td>
                    <td class="py-1">{{ schedule.hours }}</td>
                  </tr>
                  {% endfor %}
                </tbody>
              </table>
              
              <!-- Mobile list view (below lg) -->
              <div class="lg:hidden space-y-3">
                {% for schedule in client.hours.schedule %}
                <div>
                  <div class="font-medium text-gray-900 mb-1">{{ schedule.day }}</div>
                  <div class="text-sm text-gray-600">{{ schedule.hours }}</div>
                </div>
                {% endfor %}
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="hidden lg:flex p-px lg:col-span-2">
        <div class="w-full overflow-hidden rounded-lg bg-white shadow outline outline-1 outline-black/5">
          <div class="p-5 lg:p-10 flex flex-col justify-end h-full">
            <h3 class="text-lg font-semibold text-primary-500">Contact</h3>
            <div class="mt-4 space-y-3">
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                <span class="text-sm text-gray-600">{{ client.address.street }}, {{ client.address.city }}, {{ client.address.state }} {{ client.address.zip }}</span>
              </div>
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                </svg>
                <span class="text-sm text-gray-600">{{ client.phone }}</span>
              </div>
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
                <span class="text-sm text-gray-600">{{ client.email }}</span>
              </div>
            </div>
            
            {% if client.socialMedia.instagram or client.socialMedia.twitter or client.socialMedia.facebook or client.socialMedia.yelp or client.socialMedia.googleBusiness %}
            <div class="mt-auto pt-6 px-10 lg:border-t lg:border-gray-100">
              <div class="flex items-center justify-center gap-4">
                {% if client.socialMedia.instagram %}
                <a href="{{ client.socialMedia.instagram }}" target="_blank" rel="noopener noreferrer" class="text-primary-500 hover:text-primary-600">
