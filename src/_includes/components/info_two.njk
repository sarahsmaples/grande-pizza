                  </svg>
                </a>
                {% endif %}
                
                {% if client.socialMedia.twitter %}
                <a href="{{ client.socialMedia.twitter }}" target="_blank" rel="noopener noreferrer" class="text-primary-500 hover:text-primary-600">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 32 32">
                    <path d="M18.42,14.009L27.891,3h-2.244l-8.224,9.559L10.855,3H3.28l9.932,14.455L3.28,29h2.244l8.684-10.095,6.936,10.095h7.576l-10.301-14.991h0Zm-3.074,3.573l-1.006-1.439L6.333,4.69h3.447l6.462,9.243,1.006,1.439,8.4,12.015h-3.447l-6.854-9.804h0Z"/>
                  </svg>
                </a>
                {% endif %}
                
                {% if client.socialMedia.facebook %}
                <a href="{{ client.socialMedia.facebook }}" target="_blank" rel="noopener noreferrer" class="text-primary-500 hover:text-primary-600">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 32 32">
                    <path d="M16,2c-7.732,0-14,6.268-14,14,0,6.566,4.52,12.075,10.618,13.588v-9.31h-2.887v-4.278h2.887v-1.843c0-4.765,2.156-6.974,6.835-6.974,.887,0,2.417,.174,3.043,.348v3.878c-.33-.035-.904-.052-1.617-.052-2.296,0-3.183,.87-3.183,3.13v1.513h4.573l-.786,4.278h-3.787v9.619c6.932-.837,12.304-6.74,12.304-13.897,0-7.732-6.268-14-14-14Z"/>
                  </svg>
                </a>
                {% endif %}
                
                {% if client.socialMedia.yelp %}
                <a href="{{ client.socialMedia.yelp }}" target="_blank" rel="noopener noreferrer" class="text-primary-500 hover:text-primary-600">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 32 32">
                    <path d="M11.876,19.928l1.381-.319c.029-.007,.077-.018,.136-.037,.381-.102,.708-.349,.911-.688,.203-.339,.267-.743,.179-1.128-.002-.008-.004-.016-.006-.025-.045-.184-.125-.359-.234-.514-.155-.196-.346-.361-.564-.484-.256-.146-.524-.27-.801-.371l-1.515-.553c-.85-.316-1.7-.624-2.558-.925-.556-.198-1.028-.372-1.437-.498-.077-.024-.163-.048-.232-.072-.495-.152-.843-.215-1.138-.217-.197-.007-.393,.029-.574,.105-.189,.082-.359,.202-.499,.354-.069,.079-.135,.161-.195,.247-.057,.087-.109,.178-.157,.271-.052,.1-.097,.203-.134,.309-.281,.831-.421,1.703-.414,2.58,.005,.793,.026,1.811,.462,2.501,.105,.177,.246,.33,.414,.449,.31,.214,.624,.243,.951,.266,.488,.035,.96-.085,1.432-.194l4.589-1.06h.004Z"/>
